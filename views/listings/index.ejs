<% layout('layouts/boilerplate') %>

<div id="filters">
  <div class="filter">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Popular</p>
  </div>
  <div class="filter">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Private Rooms</p>
  </div>
  <div class="filter">
    <div><i class="fa-solid fa-building"></i></div>
    <p>Studios</p>
  </div>
  <div class="filter">
    <div><i class="fa-solid fa-briefcase"></i></div>
    <p>Business</p>
  </div>
  <div class="filter">
    <div><i class="fa-solid fa-water-ladder"></i></div>
    <p>Pool</p>
  </div>
  <div class="filter">
    <div><i class="fa-solid fa-car"></i></div>
    <p>Parking</p>
  </div>
  <div class="filter">
    <div><i class="fa-solid fa-mug-saucer"></i></div>
    <p>Breakfast</p>
  </div>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Show guest fees</label>
    </div>
  </div>
</div>

<div class="container-fluid px-0">
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-3 g-3 mt-1">
    <% for (let listing of allListings) { %>
      <% const pricing = listing.pricing || {}; %>
      <% const serviceFee = Math.round((listing.price * (pricing.serviceFeePercent || 0)) / 100); %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
          <div class="card h-100 shadow-sm">
            <img src="<%= listing.image?.url || listing.image %>" class="card-img-top" alt="<%= listing.title %>">
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <h5 class="card-title"><%= listing.title %></h5>
              <p class="card-text text-muted mb-1">
                <%= listing.roomType || "Private room" %> · <%= listing.location %>, <%= listing.county || listing.country %>
              </p>
              <p class="card-text">
                <b>KES <%= listing.price.toLocaleString("en-KE") %></b> / night
                <i class="tax-info"> + KES <%= serviceFee.toLocaleString("en-KE") %> service fee</i>
              </p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</div>

<script>
  const taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    const taxInfo = document.getElementsByClassName("tax-info");
    for (const info of taxInfo) {
      info.style.display = info.style.display !== "inline" ? "inline" : "none";
    }
  });
</script>
